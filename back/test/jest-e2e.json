{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "moduleNameMapper": {
    "^@mistralai/mistralai$": "<rootDir>/mocks/mistralai.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
