# Keep mock by default for deterministic hackathon demos.
# FRANCECONNECT_MODE=sandbox requires provisioned FranceConnect v2 sandbox
# credentials from the partner space; the legacy service-provider-example
# public client is not registered on the current v2 sandbox.
export FRANCECONNECT_MODE=mock
export FRANCECONNECT_CLIENT_ID=placeholder-client-id
export FRANCECONNECT_CLIENT_SECRET=placeholder-client-secret
export FRANCECONNECT_ISSUER_URL=https://fcp-low.sbx.dev-franceconnect.fr/api/v2
export FRANCECONNECT_REDIRECT_URI=http://localhost:3000/callback
export FRANCECONNECT_FALLBACK_TO_MOCK=true

export EXTERNAL_API_ADDRESS_MODE=mock
export EXTERNAL_API_GEO_MODE=mock
export EXTERNAL_API_COMPANY_MODE=mock
