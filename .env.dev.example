# Development environment (docker compose -f docker/docker-compose.dev.yml)
export NODE_ENV=development
export PORT=3000
export CORS_ORIGIN=http://localhost:5173
export FRONTEND_URL=http://localhost:5173

export POSTGRES_DB=comutitre
export POSTGRES_USER=comutitre
export POSTGRES_PASSWORD=comutitre
# In compose the app reaches the DB by its service name "db".
export DATABASE_HOST=db
export DATABASE_PORT=5432
export DATABASE_NAME=comutitre
export DATABASE_USER=comutitre
export DATABASE_PASSWORD=comutitre

export APP_JWT_SECRET=dev-only-secret-change-me-please-32
export APP_JWT_EXPIRES_IN=24h

export DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# Keep mock by default. For the FranceConnect public sandbox demo, set
# FRANCECONNECT_MODE=sandbox in your untracked .env.dev and paste the public
# integration credentials from the official service-provider-example repo.
export FRANCECONNECT_MODE=mock
export FRANCECONNECT_CLIENT_ID=placeholder-client-id
export FRANCECONNECT_CLIENT_SECRET=placeholder-client-secret
export FRANCECONNECT_ISSUER_URL=https://fcp.integ01.dev-franceconnect.fr/api/v1
export FRANCECONNECT_REDIRECT_URI=http://localhost:3000/api/auth/franceconnect/callback
export FRANCECONNECT_FALLBACK_TO_MOCK=true

export EXTERNAL_API_ADDRESS_MODE=mock
export EXTERNAL_API_GEO_MODE=mock
export EXTERNAL_API_COMPANY_MODE=mock
export EXTERNAL_API_EDUCATION_MODE=mock
export EXTERNAL_API_ELIGIBILITY_MODE=mock
export EXTERNAL_API_INTERNAL_MOBILITY_MODE=mock
export EXTERNAL_API_TIMEOUT_MS=5000
export GEOPLATEFORME_GEOCODING_URL=https://data.geopf.fr/geocodage/search
export API_GEO_BASE_URL=https://geo.api.gouv.fr
export EDUCATION_OPEN_DATA_URL=https://data.education.gouv.fr/api/explore/v2.1/catalog/datasets/fr-en-annuaire-education/records
export SIRENE_API_BASE_URL=https://api.insee.fr/api-sirene/3.11
export SIRENE_API_BEARER_TOKEN=

# YouSign API v3 — https://developers.yousign.com
export YOUSIGN_API_KEY=your-yousign-api-key-here
export YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3
export YOUSIGN_WEBHOOK_SECRET=your-yousign-webhook-secret-here
export YOUSIGN_DELIVERY_MODE=email

# ngrok — tunnel webhooks YouSign en dev (service docker, UI : http://localhost:4040)
export NGROK_AUTHTOKEN=your-ngrok-authtoken-here
