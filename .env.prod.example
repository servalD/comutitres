# Production environment (docker compose -f docker/docker-compose.prod.yml).
# In Swarm (docker/stack.prod.yml), APP_JWT_SECRET and POSTGRES_PASSWORD are
# provided as Docker secrets instead of plain env values.
# Déploiement Swarm + Traefik : le HTTPS est servi sur l'ADRESSE IP publique du
# nœud d'ingress (cert Let's Encrypt pour IP, profil shortlived). Front et back
# cohabitent derrière cette IP, séparés par chemin (/ -> front, /api -> back).
# Remplacer <IP> par l'IP publique (output Terraform `ingress_ip`).
export NODE_ENV=production
export PORT=3000
export CORS_ORIGIN=https://<IP>
export FRONTEND_URL=https://<IP>

export POSTGRES_DB=comutitre
export POSTGRES_USER=comutitre
export POSTGRES_PASSWORD=use-a-strong-secret
export DATABASE_HOST=db
export DATABASE_PORT=5432
export DATABASE_NAME=comutitre
export DATABASE_USER=comutitre
export DATABASE_PASSWORD=use-a-strong-secret

# Generate with: openssl rand -base64 32
export APP_JWT_SECRET=generate-a-strong-secret
export APP_JWT_EXPIRES_IN=1h

export DYNAMIC_ENVIRONMENT_ID=your-production-dynamic-environment-id

export FRANCECONNECT_MODE=live
export FRANCECONNECT_CLIENT_ID=your-franceconnect-client-id
export FRANCECONNECT_CLIENT_SECRET=your-franceconnect-client-secret
export FRANCECONNECT_ISSUER_URL=https://app.franceconnect.gouv.fr/api/v2

export FRANCECONNECT_REDIRECT_URI=https://<IP>/api/auth/franceconnect/callback
export FRANCECONNECT_FALLBACK_TO_MOCK=false

# External APIs. Enable live modes only after credentials and quotas are checked.
export EXTERNAL_API_ADDRESS_MODE=mock
export EXTERNAL_API_GEO_MODE=mock
export EXTERNAL_API_COMPANY_MODE=mock
export EXTERNAL_API_EDUCATION_MODE=mock
export EXTERNAL_API_ELIGIBILITY_MODE=mock
export EXTERNAL_API_INTERNAL_MOBILITY_MODE=mock
export EXTERNAL_API_TIMEOUT_MS=5000
export GEOPLATEFORME_GEOCODING_URL=https://data.geopf.fr/geocodage/search
export API_GEO_BASE_URL=https://geo.api.gouv.fr
export EDUCATION_OPEN_DATA_URL=https://data.education.gouv.fr/api/explore/v2.1/catalog/datasets/fr-en-annuaire-education/records
export SIRENE_API_BASE_URL=https://api.insee.fr/api-sirene/3.11
export SIRENE_API_BEARER_TOKEN=

# Stripe Checkout. Prefer a restricted API key (rk_*) stored in a secret manager.
# Stablecoin/Crypto must be enabled in the Stripe Dashboard payment methods.
export STRIPE_PAYMENT_MODE=mock
export STRIPE_API_KEY=
export STRIPE_WEBHOOK_SECRET=
export STRIPE_SUCCESS_URL=
export STRIPE_CANCEL_URL=
